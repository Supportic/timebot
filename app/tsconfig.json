{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "allowJs": true, // added to resolve Vue files
    "checkJs": true,
    "paths": {
      "@/*": ["assets/*"],
      "@components/*": ["assets/vue/components/*"],
      // "@types/*": ["assets/scripts/types/*"],
      // "@interfaces/*": ["assets/scripts/interfaces/*"],
      "@styles/*": ["assets/styles/*"],
      "@fonts/*": ["assets/fonts/*"],
      "@icons/*": ["assets/icons/*"]
      // "@assets/*": ["assets/vue/assets/*"],
      // "@store/*": ["assets/vue/store/*"]
    },

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "sourceMap": true,
    "types": [
      "vite/client", // replaces vite-env.d.ts
      "unplugin-fonts/client",
      "unplugin-icons/types/vue",
      "node"
    ],

    /* Linting */
    "strict": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "assets/**/*.ts",
    "assets/**/*.tsx",
    "assets/**/*.vue",
    "assets/**/*.d.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "exclude": ["public/build", "node_modules"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
