{% trans_default_domain 'app' %}

<!DOCTYPE html>
<html lang="{{ app.request.locale|replace({ '_': '-' }) }}" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {% set seoTitle -%}
        {%- block seoTitle -%}
            {# {%- block title_portal -%}{{ seo_title_portal|trim }}{%- endblock -%}
            {%- if block('title_page') is not empty %} {% block title_separator %}{{ seo_title_separator|trim }}{% endblock %} {% endif -%} #}
            {# {%- block title_page -%}{{ 'seo.title.page.default'|trans|default('') }}{%- endblock -%} #}
            {%- block title_page -%}{%- endblock -%}
        {%- endblock -%}
    {%- endset %}

    {% set seoDescription -%}
        {%- block seoDescription -%}
            {%- block description_page -%}{%- endblock -%}
        {%- endblock -%}
    {%- endset %}

    {{ render_seo_tags(seoTitle, seoDescription) }}

    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>" />
    {% block stylesheets %}
      {# for imported styles in TS file #}
      {# prevent style flash on reload in dev mode #}
      {{ vite_entry_link_tags('app') }}
      {{ vite_entry_link_tags('global') }}
    {% endblock %}

    {% block javascripts %}
      {{ vite_entry_script_tags('app') }}
      {# to activate vite HMR for .scss file #}
      {{ vite_entry_script_tags('global') }}
    {% endblock %}
  </head>
  <body
    id="top"
    {{ stimulus_controller('app') }}
    data-app-sidebar-visible-mobile-value="false"
    class="antialiased fixed size-full"
  >
    {% block body %}
      <main>
        {% block main %}
        {% endblock %}
      </main>
    {% endblock %}
  </body>
</html>
