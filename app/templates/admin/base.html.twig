{% extends 'base.html.twig' %}

{# {% block stylesheets %}
  {{ parent() }}
{% endblock %} #}

{# {% block javascripts %}
  {{ parent() }}
{% endblock %} #}

{% block body %}
  <div class="flex">
    {% block sidebar %}
      <twig:Admin:Sidebar />
    {% endblock %}

    <main class="flex flex-col flex-1 h-screen overflow-x-hidden overflow-y-auto">
      <div class="h-[60px] sticky top-0 z-1 flex items-center justify-between border-b px-3 md:px-6 shrink-0 bg-white">
        <div class="flex grow gap-x-3 items-center">
          <button id="sidebar-toggle-open" {{stimulus_action('app', 'toggleSidebarVisibility', 'click')}} class="p-2.5 relative inline-flex items-center justify-center md:hidden before:content-[''] before:absolute before:inset-0 before:m-auto before:w-6 before:h-6 before:bg-gray-50 before:rounded-full before:scale-50 hover:before:scale-200 before:opacity-0 hover:before:opacity-100 before:transition-all before:duration-400 before:ease-[cubic-bezier(0.34,1.56,0.64,1)]">
            {{ ux_icon('lucide:menu', {id: 'sidebar-toggle-open-icon','font-size': '1.5rem', class: 'z-1'}) }}
          </button>
          {% block heading -%}
            {% if heading is defined and heading is not empty -%}
              <h1 class="text-2xl">{{ heading|trim }}</h1>
            {%- endif %}
          {%- endblock %}
        </div>
        <div class="hidden md:block">
          {% include 'admin/partials/_app_version.html.twig' %}
        </div>
      </div>

      <div class="flex flex-col flex-1 has-[.breadcrumb]:pt-4 md:py-6 md:px-6 bg-gray-50">
        {% block breadcrumb %}
          {# <div class="breadcrumb mb-4 bg-white rounded p-2">
            <p>breadcrumb</p>
          </div> #}
        {% endblock %}

        <div class="grid grid-cols-12 gap-4 md:gap-6 flex-1 overflow-x-auto bg-white md:shadow-lg md:rounded-md p-5 w-full">
          {% block content %}

          {% endblock %}
        </div>
      </div>
    </main>
  </div>
{% endblock %}
