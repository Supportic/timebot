/.docker/data/logs/*
/.docker/bin/*

/.env

# +----------------------------+
# |    Keep .gitkeep files     |
# +----------------------------+-------------------------------+
# | To keep an empty directory, add a .gitkeep file to it      |
# | and ignore the directory with a wildcard:                  |
# |                                                            |
# |     /path/to/dir/*                                         |
# |                                                            |
# | this will ignore the content but not the directory itself. |
# +------------------------------------------------------------+
!.gitkeep

# +----------------------------+
# |    Keep .gitignore files     |
# +----------------------------+-------------------------------+
# | To keep an empty directory, add a .gitignore file to it    |
# | with the following content:                                |
# |                                                            |
# |     *                                                      |
# |     !.gitignore                                            |
# |                                                            |
# | this will ignore the content but not the directory itself. |
# +------------------------------------------------------------+
!.gitignore
